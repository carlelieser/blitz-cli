{
  "file": "src/createWindow.js",
  "description": "Injects a MutationObserver via executeJavaScript on did-finish-load to hide ad slot elements via CSS without removing them from the DOM",
  "type": "insert_after_regex",
  "pattern": "browserView\\.webContents\\.loadURL\\(url\\);",
  "insert": "\n  browserView.webContents.on(\"did-finish-load\", () => {\n    browserView.webContents.executeJavaScript(\n      \"(function() { var _style = document.createElement('style'); _style.textContent = '[class*=\\\"\\\\uD83E\\\\uDD11-column\\\"],[class*=\\\"\\\\uD83E\\\\uDD11-container\\\"],[class*=\\\"display-\\\\uD83E\\\\uDD11\\\"],[class*=\\\"\\\\uD83E\\\\uDD11-column\\\"] *{display:none!important;width:0!important;height:0!important;overflow:hidden!important;} img[src^=\\\"https://blitz-cdn.blitz.gg/self-promotion\\\"]{display:none!important;} .route-wrapper{width:100%!important;}'; document.head.appendChild(_style); }());\"\n    ).catch(function() {});\n  });"
}
