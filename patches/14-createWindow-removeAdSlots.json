{
  "file": "src/createWindow.js",
  "description": "Removes ad slot elements from the DOM on did-finish-load",
  "type": "insert_after_regex",
  "pattern": "browserView\\.webContents\\.loadURL\\(url\\);",
  "insert": "\n  browserView.webContents.on(\"did-finish-load\", () => {\n    browserView.webContents.executeJavaScript(\n      \"document.querySelectorAll('[class*=\\\"\\\\uD83E\\\\uDD11-column\\\"],[class*=\\\"\\\\uD83E\\\\uDD11-container\\\"],[class*=\\\"display-\\\\uD83E\\\\uDD11\\\"]').forEach(function(el) { el.remove(); });\"\n    ).catch(function() {});\n  });"
}
