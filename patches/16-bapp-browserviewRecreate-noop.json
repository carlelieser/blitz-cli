{
  "file": "src/listeners/bapp.js",
  "description": "No-op BROWSERVIEW_RECREATE to prevent BrowserView recreation that logs the user out",
  "type": "replace",
  "find": "addListener(EvTypes.BROWSERVIEW_RECREATE, (url) => {\n  reCreateBrowserView(url);\n});",
  "replace": "addListener(EvTypes.BROWSERVIEW_RECREATE, (url) => {\n  return;\n});"
}
